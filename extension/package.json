{
  "name": "extension",
  "displayName": "Extension",
  "version": "0.0.1",
  "description": "An extension for the people in need",
  "author": "Pratham Jain",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "@plasmohq/storage": "^1.15.0",
    "color2k": "^2.0.4",
    "hyphenation.en-us": "^0.2.1",
    "hypher": "^0.2.5",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "autoprefixer": "^10.5.4",
    "postcss": "^8.5.19",
    "prettier": "3.2.4",
    "tailwindcss": "^3.4.19",
    "typescript": "5.3.3"
  },
  "manifest": {
    "permissions": [
      "contextMenus",
      "activeTab",
      "tabs"
    ],
    "host_permissions": [
      "https://*/*",
      "http://*/*",
      "file:///*"
    ],
     "externally_connectable": {
      "matches": [
        "http://localhost:5173/*",
        "http://localhost:8000/*"
      ]
    }
  }
}
